# ---------------------------------------------------------------------------
# GraphQL API
# ---------------------------------------------------------------------------
GRAPHQL_ENDPOINT=
GRAPHQL_AUTH_HEADER=

# ---------------------------------------------------------------------------
# Monday.com
# ---------------------------------------------------------------------------
MONDAY_API_KEY=
MONDAY_PROJECTS_BOARD_ID=
MONDAY_PEOPLE_BOARD_ID=

# Monday.com column IDs
# These are sourced from the POC board and may change during RN-192 board audit.
# Always reference via these env vars — never hardcode column IDs.
MONDAY_COL_ASSIGNED_PERSON=
MONDAY_COL_STATUS=
MONDAY_COL_DATE=
MONDAY_COL_CONTENT_TYPE=dr4s
MONDAY_COL_DESCRIPTION=
MONDAY_COL_ITEM_NAME=
# MONDAY_COL_SUBMITTER_EMAIL=     

